<div id="draw-data" data-session-id={@session_id}></div>

<div class="min-h-screen flex flex-col select-none">
  <canvas id="draw-canvas" class="flex-1 w-full touch-none" style="cursor: crosshair;"></canvas>
  <div class="flex items-center justify-between px-6 py-3 bg-base-200">
    <span class="text-sm text-base-content/50">Draw with your finger</span>
    <button id="clear-btn" class="btn btn-sm btn-ghost">Clear</button>
  </div>
</div>
